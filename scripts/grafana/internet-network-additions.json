  {
    "decimals": 2,
    "desc": "Real inbound Cloudflare traffic broken into status classes (collapsing 16 distinct codes); a sustained 5xx rate is origin errors through the tunnel that synthetic blackbox probes may miss, and total QPS doubles as the public-traffic-volume view.",
    "h": 8,
    "hints": {},
    "priority": "P0",
    "row": "Cloudflare Tunnel / Edge",
    "row_key": "cloudflare",
    "steps": [
      {
        "color": "green",
        "value": null
      }
    ],
    "targets": [
      {
        "expr": "sum(rate(cloudflared_tunnel_response_by_code{status_code=~\"2..\"}[$__rate_interval]))",
        "instant": false,
        "legend": "2xx"
      },
      {
        "expr": "sum(rate(cloudflared_tunnel_response_by_code{status_code=~\"3..\"}[$__rate_interval]))",
        "instant": false,
        "legend": "3xx"
      },
      {
        "expr": "sum(rate(cloudflared_tunnel_response_by_code{status_code=~\"4..\"}[$__rate_interval]))",
        "instant": false,
        "legend": "4xx"
      },
      {
        "expr": "sum(rate(cloudflared_tunnel_response_by_code{status_code=~\"5..\"}[$__rate_interval]))",
        "instant": false,
        "legend": "5xx"
      }
    ],
    "title": "Edge responses by HTTP status class (/s)",
    "type": "timeseries",
    "unit": "reqps",
    "w": 12
  },
  {
    "decimals": 2,
    "desc": "Fraction of tunnel requests cloudflared failed to proxy to the origin; clamp_min keeps it numeric during idle windows and catches a degraded-but-up ingress (edge connected, rproxy flaky).",
    "h": 4,
    "hints": {},
    "priority": "P1",
    "row": "Cloudflare Tunnel / Edge",
    "row_key": "cloudflare",
    "steps": [
      {
        "color": "green",
        "value": null
      },
      {
        "color": "yellow",
        "value": 1
      },
      {
        "color": "red",
        "value": 5
      }
    ],
    "targets": [
      {
        "expr": "sum(rate(cloudflared_tunnel_request_errors[$__rate_interval])) / clamp_min(sum(rate(cloudflared_tunnel_total_requests[$__rate_interval])), 0.0001) * 100",
        "instant": false,
        "legend": "error %"
      }
    ],
    "title": "Tunnel error ratio %",
    "type": "stat",
    "unit": "percent",
    "w": 4
  },
  {
    "decimals": 0,
