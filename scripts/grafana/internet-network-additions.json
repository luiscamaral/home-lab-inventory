  {
    "decimals": 1,
    "desc": "Per-replica tunnel-path latency to the Cloudflare edge over QUIC (values already in ms, do NOT scale); rising QUIC RTT with healthy WAN RTT points to an edge-path/ISP-peering problem the gateway RTT cannot see.",
    "h": 8,
    "hints": {},
    "priority": "P2",
    "row": "Cloudflare Tunnel / Edge",
    "row_key": "cloudflare",
    "steps": [
      {
        "color": "green",
        "value": null
      },
      {
        "color": "yellow",
        "value": 30
      },
      {
        "color": "red",
        "value": 80
      }
    ],
    "targets": [
      {
        "expr": "avg by (instance) (quic_client_smoothed_rtt)",
        "instant": false,
        "legend": "{{instance}} smoothed"
      },
      {
        "expr": "max by (instance) (quic_client_latest_rtt)",
        "instant": false,
        "legend": "{{instance}} latest(max)"
      }
    ],
    "title": "QUIC RTT to Cloudflare edge (ms)",
    "type": "timeseries",
    "unit": "ms",
    "w": 12
  },
  {
    "decimals": 2,
    "desc": "Edge-path packet loss summed across the 4 QUIC conns per replica (collapsing the timeout/reordering reason label); captures congestion on the tunnel's UDP/443 route that the pfSense gateway loss_ratio cannot, since QUIC takes a different path.",
    "h": 8,
    "hints": {},
    "priority": "P2",
    "row": "Cloudflare Tunnel / Edge",
    "row_key": "cloudflare",
    "steps": [
      {
        "color": "green",
        "value": null
      },
      {
        "color": "yellow",
        "value": 0.5
      },
      {
        "color": "red",
        "value": 5
