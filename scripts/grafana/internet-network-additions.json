    "h": 4,
    "hints": {},
    "priority": "P0",
    "row": "Cloudflare Tunnel / Edge",
    "row_key": "cloudflare",
    "steps": [
      {
        "color": "red",
        "value": null
      },
      {
        "color": "yellow",
        "value": 2
      },
      {
        "color": "green",
        "value": 4
      }
    ],
    "targets": [
      {
        "expr": "min(cloudflared_tunnel_ha_connections)",
        "instant": false,
        "legend": "min HA conns"
      }
    ],
    "title": "\ud83d\udfe7 Tunnel edge connections (min HA)",
    "type": "stat",
    "unit": "none",
    "w": 4
  },
  {
    "decimals": 0,
