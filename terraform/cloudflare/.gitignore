# Terraform state (contains secrets)
*.tfstate
*.tfstate.*

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Variable override files (may contain secrets)
*.tfvars
*.tfvars.json
*.auto.tfvars

# Plan files
*.tfplan

# Downloaded terraform binary (cf-terraforming artifact)
terraform
