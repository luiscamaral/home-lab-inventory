      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "thanos"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
