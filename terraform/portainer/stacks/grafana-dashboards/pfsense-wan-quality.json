          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "thanos"
        },
        "includeAll": true,
        "label": "Gateway",
        "multi": true,
        "name": "gateway",
        "query": "label_values(pfsense_gateway_delay_seconds, gateway)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
